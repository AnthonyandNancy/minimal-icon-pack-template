<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Remote wallpaper previews need internet access. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.SET_WALLPAPER" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!--
        Strip the DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION that
        androidx.core injects into the merged manifest.
        This permission contains the applicationId in its name.
        After apktool decompile + package rename, a hardcoded
        old-package permission name causes a crash.
        Removing it at source eliminates the problem entirely.
    -->
    <permission
        android:name="${applicationId}.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        tools:node="remove" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.IconPackTemplate"
        android:usesCleartextTraffic="true"
        tools:targetApi="35">

        <!-- Main Activity: MUST use fully qualified class name for apktool -->
        <activity
            android:name="com.template.iconpack.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.IconPackTemplate"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">

            <!-- Launcher entry -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- App drawer info -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.INFO" />
            </intent-filter>

            <!-- Standard ADW icon-pack entry used by Samsung Theme Park and most launchers. -->
            <intent-filter>
                <action android:name="org.adw.ActivityStarter.THEMES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Legacy ADW / LauncherPro theme picker -->
            <intent-filter>
                <action android:name="org.adw.launcher.THEMES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Icon picker -->
            <intent-filter>
                <action android:name="org.adw.launcher.icons.ACTION_PICK_ICON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Nova / Action Launcher apply -->
            <intent-filter>
                <action android:name="com.novalauncher.THEME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>

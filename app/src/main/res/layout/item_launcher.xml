<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="84dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/glass_card_secondary"
    app:strokeColor="@color/glass_stroke_bright"
    app:strokeWidth="0.5dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:background="@drawable/glass_circle_container"
            android:layout_marginEnd="14dp">

            <ImageView
                android:id="@+id/launcher_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_apply_card"
                android:tint="@color/primary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/launcher_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/entry_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击查看应用方式"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_info"
            android:tint="@color/text_hint"
            android:rotation="180" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

<?xml version="1.0" encoding="utf-8"?>
<!-- ENTRY CARD: FrameLayout + glass drawable — NO MaterialCardView -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:background="@drawable/glass_card_entry"
    android:elevation="3dp"
    android:clipChildren="false"
    android:clickable="true"
    android:focusable="true"
    android:outlineProvider="background"
    android:foreground="?attr/selectableItemBackground"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Icon circle -->
        <LinearLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:background="@drawable/glass_circle_container"
            android:layout_marginEnd="14dp">

            <ImageView
                android:id="@+id/launcher_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_apply_card"
                android:tint="#5EA8FF" />

        </LinearLayout>

        <!-- Title + description -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/launcher_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#F9FAFB"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/entry_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#9CA3AF"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Arrow -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_info"
            android:tint="#9CA3AF"
            android:rotation="180" />

    </LinearLayout>

</FrameLayout>

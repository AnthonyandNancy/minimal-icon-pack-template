<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/quick_item_height"
    app:cardCornerRadius="@dimen/radius_quick_item"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/color_card_stroke_light"
    app:cardBackgroundColor="@color/color_card_surface"
    android:layout_marginBottom="@dimen/quick_item_gap">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/quick_item_padding_start"
        android:paddingEnd="@dimen/quick_item_padding_end">

        <FrameLayout
            android:id="@+id/launcher_badge"
            android:layout_width="@dimen/quick_badge_size"
            android:layout_height="@dimen/quick_badge_size">
            <ImageView
                android:id="@+id/launcher_icon"
                android:layout_width="@dimen/quick_badge_icon_size"
                android:layout_height="@dimen/quick_badge_icon_size"
                android:layout_gravity="center"
                android:scaleType="centerInside"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/launcher_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/quick_title_size"
                android:textColor="@color/color_text_primary"
                android:maxLines="1"
                android:includeFontPadding="false"/>

            <TextView
                android:id="@+id/entry_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/quick_subtitle_size"
                android:textColor="@color/color_text_tertiary"
                android:maxLines="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <ImageView
            android:layout_width="@dimen/quick_arrow_size"
            android:layout_height="@dimen/quick_arrow_size"
            android:src="@drawable/ic_arrow_right"
            android:tint="@color/color_text_tertiary"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

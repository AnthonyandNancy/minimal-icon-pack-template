<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardBackgroundColor="@color/glass_card"
    app:cardCornerRadius="28dp"
    app:cardElevation="8dp"
    app:strokeColor="@color/glass_stroke_bright"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="560dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_surface_card">

                <ImageView
                    android:id="@+id/icon_preview_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:padding="28dp"
                    android:scaleType="centerInside" />
            </FrameLayout>

            <TextView
                android:id="@+id/icon_preview_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/icon_preview_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_preview_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:layout_margin="14dp"
            android:background="@drawable/glass_btn_bg"
            android:contentDescription="@string/cancel"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_close"
            android:tint="@color/text_primary" />
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>

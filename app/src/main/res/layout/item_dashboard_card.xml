<?xml version="1.0" encoding="utf-8"?>
<!-- STAT CARD: FrameLayout + glass drawable — NO MaterialCardView, NO white rectangles -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:background="@drawable/glass_card_stat"
    android:elevation="4dp"
    android:clipChildren="false"
    android:clickable="true"
    android:focusable="true"
    android:outlineProvider="background"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Icon container (small tinted circle, NOT white square) -->
        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:background="@drawable/glass_stat_icon_container"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/card_icon"
                android:layout_width="20dp"
                android:layout_height="20dp" />

        </LinearLayout>

        <!-- Stat number -->
        <TextView
            android:id="@+id/card_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="30sp"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:textColor="#3B82F6" />

        <!-- Label -->
        <TextView
            android:id="@+id/card_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#5F6B7A"
            android:includeFontPadding="false"
            android:layout_marginTop="8dp" />

        <!-- Optional description (hidden by default) -->
        <TextView
            android:id="@+id/card_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>

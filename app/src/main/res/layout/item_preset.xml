<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="96dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/glass_card"
    app:strokeColor="@color/glass_stroke_bright"
    app:strokeWidth="0.5dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <View
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/glass_preset_preview"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/preset_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#F9FAFB"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/preset_shape"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#B6C2D2"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="启用"
            android:textSize="12sp"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/glass_chip_selected"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
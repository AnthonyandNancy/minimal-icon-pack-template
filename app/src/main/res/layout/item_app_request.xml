<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:background="@drawable/bg_surface_card"
    android:elevation="2dp"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:outlineProvider="background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp" android:paddingEnd="14dp">

        <CheckBox android:id="@+id/request_checkbox"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginEnd="10dp" android:visibility="gone" />

        <ImageView android:id="@+id/request_icon"
            android:layout_width="44dp" android:layout_height="44dp"
            android:scaleType="centerInside" android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">

            <TextView android:id="@+id/request_app_name"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="15sp" android:textColor="@color/text_primary" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end" />

            <TextView android:id="@+id/request_package_name"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="@color/text_hint"
                android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>

        <TextView android:id="@+id/request_status"
            android:layout_width="wrap_content" android:layout_height="26dp"
            android:gravity="center" android:textSize="11sp" android:textColor="@color/text_on_primary"
            android:paddingStart="10dp" android:paddingEnd="10dp"
            android:background="@drawable/bg_badge_green" />

    </LinearLayout>
</FrameLayout>

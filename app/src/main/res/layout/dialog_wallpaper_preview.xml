<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardBackgroundColor="@color/glass_card"
    app:cardCornerRadius="28dp"
    app:cardElevation="8dp"
    app:strokeColor="@color/glass_stroke_bright"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="560dp">

        <ImageView
            android:id="@+id/wallpaper_preview_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/divider"
            android:scaleType="centerCrop" />

        <ImageButton
            android:id="@+id/btn_preview_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:layout_margin="14dp"
            android:background="@drawable/glass_btn_bg"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_close"
            android:tint="@color/text_primary" />

        <TextView
            android:id="@+id/btn_preview_apply"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_gravity="bottom"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_pill_primary"
            android:gravity="center"
            android:text="@string/wallpapers_apply"
            android:textColor="@color/text_on_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/drawer_header_height"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/glass_drawer_header_bg">

    <ImageView
        android:id="@+id/nav_logo"
        android:layout_width="@dimen/nav_logo_size"
        android:layout_height="@dimen/nav_logo_size"
        android:src="@mipmap/ic_launcher"
        android:scaleType="centerCrop"
        android:background="@drawable/glass_circle_container"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/nav_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/nav_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/version_name"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

</LinearLayout>
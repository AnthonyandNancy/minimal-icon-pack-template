<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginTop="6dp" android:layout_marginBottom="6dp">

    <TextView android:id="@+id/filter_all"
        android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
        android:gravity="center" android:text="全部" android:textSize="11sp"
        android:textColor="#FFFFFF" android:background="@drawable/glass_chip_selected"
        android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" />
    <TextView android:id="@+id/filter_themed"
        android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
        android:gravity="center" android:text="已适配" android:textSize="11sp"
        android:textColor="#4A4A6A" android:background="@drawable/glass_chip_unselected"
        android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" />
    <TextView android:id="@+id/filter_unthemed"
        android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
        android:gravity="center" android:text="未适配" android:textSize="11sp"
        android:textColor="#4A4A6A" android:background="@drawable/glass_chip_unselected"
        android:layout_marginEnd="5dp"         android:clickable="true" android:focusable="true" />
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.IconPack.Card.List"
    android:layout_width="match_parent"
    android:layout_height="@dimen/quick_item_height"
    android:layout_marginBottom="@dimen/quick_item_gap">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/quick_item_padding_start"
        android:paddingEnd="@dimen/quick_item_padding_end">

        <FrameLayout
            android:id="@+id/entry_badge"
            android:layout_width="@dimen/quick_badge_size"
            android:layout_height="@dimen/quick_badge_size">

            <ImageView
                android:id="@+id/entry_icon"
                android:layout_width="@dimen/quick_badge_icon_size"
                android:layout_height="@dimen/quick_badge_icon_size"
                android:layout_gravity="center"
                android:scaleType="centerInside" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/entry_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/quick_title_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/entry_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/quick_subtitle_size" />
        </LinearLayout>

        <ImageView
            android:layout_width="@dimen/quick_arrow_size"
            android:layout_height="@dimen/quick_arrow_size"
            android:src="@drawable/ic_arrow_right"
            android:tint="@color/color_text_tertiary" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

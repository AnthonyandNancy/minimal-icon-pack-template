<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">
    <View android:id="@+id/status_spacer"
        android:layout_width="match_parent" android:layout_height="16dp" />

    <!-- Glass pill bar -->
    <LinearLayout
        android:id="@+id/backbar_pill"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp" android:paddingEnd="14dp"
        android:background="@drawable/glass_backbar_bg"
        android:elevation="4dp"
        android:outlineProvider="background">

        <ImageButton android:id="@+id/btn_back"
            android:layout_width="36dp" android:layout_height="36dp"
            android:background="@drawable/glass_btn_bg"
            android:src="@drawable/ic_back_arrow" android:tint="#3D3D5C"
            android:scaleType="centerInside"
            android:clickable="true" android:focusable="true"
            android:onClick="onBackClicked"
            android:layout_marginEnd="8dp" />

        <TextView android:id="@+id/page_title"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="20sp" android:textStyle="bold"
            android:textColor="#1A1A2E" android:layout_marginStart="10dp" />
    </LinearLayout>
</LinearLayout>

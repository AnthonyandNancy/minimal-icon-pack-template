<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">
    <View android:id="@+id/status_spacer"
        android:layout_width="match_parent" android:layout_height="16dp" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp" android:paddingEnd="16dp"
        android:layout_marginTop="8dp">
        <ImageButton android:id="@+id/btn_back"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="@drawable/glass_btn_bg"
            android:src="@drawable/ic_back_arrow" android:tint="#E5E7EB"
            android:scaleType="centerInside" />
        <TextView android:id="@+id/page_title"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="20sp" android:textStyle="bold"
            android:textColor="#F9FAFB" android:layout_marginStart="10dp" />
    </LinearLayout>
</LinearLayout>

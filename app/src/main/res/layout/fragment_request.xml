<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Stats header + Filter bar (fixed above RecyclerView) -->
    <LinearLayout android:id="@+id/request_header"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp" android:paddingEnd="24dp"
        android:paddingTop="80dp"
        android:elevation="2dp"
        android:background="#F7F4EE">

        <!-- Stats card -->
        <LinearLayout android:id="@+id/stats_card"
            android:layout_width="match_parent" android:layout_height="100dp"
            android:orientation="horizontal" android:gravity="center"
            android:background="@drawable/glass_card_stat"
            android:elevation="1dp"
            android:layout_marginBottom="12dp"
            android:paddingStart="16dp" android:paddingEnd="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/stat_total" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="24sp"
                    android:textStyle="bold" android:textColor="#6C63FF" android:text="0"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="#6E6A78" android:text="Total"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/stat_themed" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="24sp"
                    android:textStyle="bold" android:textColor="#22C55E" android:text="0"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="#6E6A78" android:text="Themed"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/stat_unthemed" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="24sp"
                    android:textStyle="bold" android:textColor="#EF4444" android:text="0"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="#6E6A78" android:text="Missing"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Filter pills -->
        <LinearLayout android:id="@+id/filter_bar"
            android:layout_width="match_parent" android:layout_height="38dp"
            android:orientation="horizontal" android:gravity="center"
            android:layout_marginBottom="6dp">
            <TextView android:id="@+id/filter_all" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:gravity="center" android:text="@string/request_all" android:textSize="12sp"
                android:textColor="#FFFFFF" android:background="@drawable/glass_chip_selected"
                android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/filter_themed" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:gravity="center" android:text="@string/request_themed_filter" android:textSize="12sp"
                android:textColor="#4A4A6A" android:background="@drawable/glass_chip_unselected"
                android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/filter_unthemed" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:gravity="center" android:text="@string/request_unthemed_filter" android:textSize="12sp"
                android:textColor="#4A4A6A" android:background="@drawable/glass_chip_unselected"
                android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/filter_selected" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:gravity="center" android:text="Selected" android:textSize="12sp"
                android:textColor="#4A4A6A" android:background="@drawable/glass_chip_unselected"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- RecyclerView: app list only, starts below header -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/request_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="206dp"
        android:paddingBottom="90dp" />

    <!-- Top back bar -->
    <include
        android:id="@+id/request_backbar"
        layout="@layout/include_backbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="10dp" />

    <!-- Bottom floating bar -->
    <LinearLayout android:id="@+id/request_bottom_bar"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/glass_floating_bar"
        android:gravity="center" android:orientation="horizontal"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:elevation="14dp"
        android:visibility="gone">

        <TextView android:id="@+id/selected_count_text"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="13sp" android:textColor="#6E6A78" />

        <TextView android:id="@+id/btn_select_all"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:gravity="center" android:text="Select All" android:textSize="11sp"
            android:textColor="#4A4A6A" android:background="@drawable/glass_chip_unselected"
            android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginEnd="6dp"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btn_export"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:gravity="center" android:text="@string/request_export" android:textSize="11sp"
            android:textColor="#FFFFFF" android:background="@drawable/glass_chip_selected"
            android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginEnd="6dp"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btn_share"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:gravity="center" android:text="@string/request_share" android:textSize="11sp"
            android:textColor="#FFFFFF" android:background="@drawable/glass_chip_selected"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top bar: fixed -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View android:id="@+id/status_spacer_req"
            android:layout_width="match_parent" android:layout_height="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp" android:paddingEnd="16dp">

            <ImageButton android:id="@+id/btn_back_req"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="@drawable/glass_btn_bg"
                android:src="@drawable/ic_back_arrow" android:tint="#243044"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/request_title" android:textSize="20sp"
                android:textStyle="bold" android:textColor="#111827"
                android:layout_marginStart="10dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Single RecyclerView: header (stats+filter) + app list, unified scroll -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/request_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="70dp"
        android:paddingBottom="90dp" />

    <!-- Bottom bar: fixed -->
    <LinearLayout android:id="@+id/request_bottom_bar"
        android:layout_width="match_parent" android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp" android:layout_marginEnd="20dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/glass_floating_bar"
        android:gravity="center_vertical" android:orientation="horizontal"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:elevation="14dp"
        android:visibility="visible">

        <!-- Spacer to push buttons to center -->
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <TextView android:id="@+id/btn_select_all"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:gravity="center" android:text="全选" android:textSize="12sp"
            android:textColor="#243044" android:background="@drawable/glass_chip_unselected"
            android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginEnd="8dp"
            android:clickable="true" android:focusable="true"
            android:visibility="gone" />

        <TextView android:id="@+id/btn_export"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center" android:text="@string/request_export" android:textSize="12sp"
            android:textColor="@color/text_on_primary" android:background="@drawable/glass_chip_selected"
            android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginEnd="8dp"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btn_share"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center" android:text="@string/request_share" android:textSize="12sp"
            android:textColor="@color/text_on_primary" android:background="@drawable/glass_chip_selected"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:clickable="true" android:focusable="true" />

    </LinearLayout>

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Stats bar + Filter bar (fixed top) -->
    <LinearLayout android:id="@+id/request_header"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="4dp"
        android:elevation="4dp"
        android:background="@color/background">

        <!-- Back bar -->
        <include layout="@layout/include_backbar"/>

        <!-- Subtitle -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="选择未适配应用，复制信息或发邮件申请"
            android:textColor="@color/text_secondary" android:textSize="13sp"
            android:layout_marginTop="4dp" android:layout_marginBottom="10dp"/>

        <!-- Stats strip -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center"
            android:background="@drawable/bg_surface_card" android:elevation="1dp"
            android:layout_marginBottom="10dp"
            android:paddingStart="8dp" android:paddingEnd="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/stat_total" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="20sp"
                    android:textStyle="bold" android:textColor="@color/primary" android:text="0"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="@color/text_secondary" android:text="总计"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/stat_themed" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="20sp"
                    android:textStyle="bold" android:textColor="@color/status_themed" android:text="0"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="@color/text_secondary" android:text="已适配"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/stat_unthemed" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="20sp"
                    android:textStyle="bold" android:textColor="@color/status_unthemed" android:text="0"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="@color/text_secondary" android:text="未适配"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Filter chips -->
        <LinearLayout android:id="@+id/filter_bar"
            android:layout_width="match_parent" android:layout_height="36dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView android:id="@+id/filter_all" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:gravity="center" android:text="全部" android:textSize="12sp"
                android:textColor="@color/text_on_primary" android:background="@drawable/bg_chip_selected"
                android:layout_marginEnd="6dp"
                android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/filter_themed" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:gravity="center" android:text="已适配" android:textSize="12sp"
                android:textColor="@color/text_secondary" android:background="@drawable/bg_surface_card"
                android:layout_marginEnd="6dp"
                android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/filter_unthemed" android:layout_width="0dp"
                android:layout_height="match_parent" android:layout_weight="1"
                android:gravity="center" android:text="未适配" android:textSize="12sp"
                android:textColor="@color/text_secondary" android:background="@drawable/bg_surface_card"
                android:layout_marginEnd="6dp"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- App list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/request_list"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="220dp"
        android:paddingBottom="116dp"/>

    <!-- Bottom bar -->
    <LinearLayout android:id="@+id/request_bottom_bar"
        android:layout_width="match_parent" android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_surface_card"
        android:gravity="center_vertical" android:orientation="horizontal"
        android:paddingStart="16dp" android:paddingEnd="10dp"
        android:elevation="12dp"
        android:visibility="gone">

        <TextView android:id="@+id/selected_count_text"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="14sp" android:textColor="@color/text_primary"/>

        <TextView android:id="@+id/btn_select_all"
            android:layout_width="wrap_content" android:layout_height="44dp"
            android:gravity="center" android:text="全选" android:textSize="13sp"
            android:textColor="@color/primary" android:background="@drawable/bg_surface_card"
            android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginEnd="8dp"
            android:clickable="true" android:focusable="true"/>

        <TextView android:id="@+id/btn_export"
            android:layout_width="wrap_content" android:layout_height="44dp"
            android:gravity="center" android:text="@string/request_export" android:textSize="13sp"
            android:textColor="@color/text_on_primary" android:background="@drawable/bg_chip_selected"
            android:paddingStart="18dp" android:paddingEnd="18dp" android:layout_marginEnd="8dp"
            android:clickable="true" android:focusable="true"/>

        <TextView android:id="@+id/btn_share"
            android:layout_width="wrap_content" android:layout_height="44dp"
            android:gravity="center" android:text="@string/request_share" android:textSize="13sp"
            android:textColor="@color/primary" android:background="@drawable/bg_surface_card"
            android:paddingStart="18dp" android:paddingEnd="18dp"
            android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/request_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="true"
        android:focusable="true"
        android:elevation="32dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_surface_card"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="22dp"
            android:paddingEnd="24dp"
            android:paddingBottom="22dp">

            <ProgressBar
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:indeterminate="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="正在生成申请包..."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="应用较多时请稍候"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>

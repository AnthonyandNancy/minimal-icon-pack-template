<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 1. FIXED top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View android:id="@+id/status_spacer_req"
            android:layout_width="match_parent" android:layout_height="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp" android:paddingEnd="16dp">

            <ImageButton android:id="@+id/btn_back_req"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="@drawable/glass_btn_bg"
                android:src="@drawable/ic_back_arrow" android:tint="#E5E7EB"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/request_title" android:textSize="20sp"
                android:textStyle="bold" android:textColor="#F9FAFB"
                android:layout_marginStart="10dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 2. SCROLLABLE: stats + filters + list, all scroll together -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="70dp"
        android:paddingBottom="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp" android:paddingEnd="24dp">

            <!-- Stats card — single layer, no MaterialCardView -->
            <FrameLayout
                android:id="@+id/request_stats_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/glass_card_stat"
                android:elevation="2dp"
                android:outlineProvider="background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp" android:paddingEnd="18dp"
                    android:paddingTop="14dp" android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:id="@+id/stat_total"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="24sp" android:textStyle="bold" android:textColor="#5EA8FF" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="已安装" android:textSize="11sp" android:textColor="#8FA0B5" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:id="@+id/stat_themed"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="24sp" android:textStyle="bold" android:textColor="#34D399" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="已适配" android:textSize="11sp" android:textColor="#8FA0B5" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content" android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:id="@+id/stat_unthemed"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="24sp" android:textStyle="bold" android:textColor="#FDBA3B" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="未适配" android:textSize="11sp" android:textColor="#8FA0B5" />
                        </LinearLayout>
                    </LinearLayout>

                    <ProgressBar android:id="@+id/request_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="4dp"
                        android:layout_marginTop="8dp"
                        android:progressDrawable="@drawable/glass_progress" />
                </LinearLayout>
            </FrameLayout>

            <!-- Filter chips -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp" android:layout_marginBottom="10dp">

                <TextView android:id="@+id/filter_all"
                    android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                    android:gravity="center" android:text="@string/request_all" android:textSize="11sp"
                    android:textColor="@color/text_on_primary" android:background="@drawable/glass_chip_selected"
                    android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" />
                <TextView android:id="@+id/filter_themed"
                    android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                    android:gravity="center" android:text="已适配" android:textSize="11sp"
                    android:textColor="@color/text_secondary" android:background="@drawable/glass_chip_unselected"
                    android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" />
                <TextView android:id="@+id/filter_unthemed"
                    android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                    android:gravity="center" android:text="未适配" android:textSize="11sp"
                    android:textColor="@color/text_secondary" android:background="@drawable/glass_chip_unselected"
                    android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" />
                <TextView android:id="@+id/filter_selected"
                    android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                    android:gravity="center" android:text="已选择" android:textSize="11sp"
                    android:textColor="@color/text_secondary" android:background="@drawable/glass_chip_unselected"
                    android:clickable="true" android:focusable="true" />
            </LinearLayout>

            <!-- App list (nestedScrolling disabled, inside same ScrollView) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/request_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <!-- 3. FIXED bottom bar: select-all / export / share only -->
    <LinearLayout android:id="@+id/request_bottom_bar"
        android:layout_width="match_parent" android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp" android:layout_marginEnd="20dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/glass_floating_bar"
        android:gravity="center_vertical" android:orientation="horizontal"
        android:paddingStart="14dp" android:paddingEnd="12dp"
        android:elevation="14dp"
        android:visibility="visible">

        <TextView android:id="@+id/request_selected_count"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text=""
            android:textSize="13sp" android:textColor="#B6C2D2" />

        <TextView android:id="@+id/btn_select_all"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:gravity="center" android:text="全选" android:textSize="12sp"
            android:textColor="#E5E7EB" android:background="@drawable/glass_chip_unselected"
            android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginEnd="8dp"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btn_export"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:gravity="center" android:text="@string/request_export" android:textSize="12sp"
            android:textColor="@color/text_on_primary" android:background="@drawable/glass_chip_selected"
            android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginEnd="8dp"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btn_share"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:gravity="center" android:text="@string/request_share" android:textSize="12sp"
            android:textColor="@color/text_on_primary" android:background="@drawable/glass_chip_selected"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:clickable="true" android:focusable="true" />

    </LinearLayout>

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 1. FIXED top bar: back arrow + title -->
    <LinearLayout
        android:id="@+id/request_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- status spacer -->
        <View android:id="@+id/status_spacer_req"
            android:layout_width="match_parent" android:layout_height="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp" android:paddingEnd="16dp">

            <ImageButton android:id="@+id/btn_back_req"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="@drawable/glass_btn_bg"
                android:src="@drawable/ic_back_arrow" android:tint="#E5E7EB"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/request_title" android:textSize="22sp"
                android:textStyle="bold" android:textColor="#F9FAFB"
                android:layout_marginStart="12dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 2. SCROLLABLE body: stats + filters + list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="88dp"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp" android:paddingEnd="24dp">

            <!-- Stats card — compact -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/request_stats_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/glass_card_primary"
                app:strokeColor="@color/glass_stroke_dim"
                app:strokeWidth="0.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp" android:paddingEnd="20dp"
                    android:paddingTop="16dp" android:paddingBottom="12dp">

                    <!-- 3-column stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <LinearLayout
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:id="@+id/stat_total"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="26sp" android:textStyle="bold" android:textColor="#5EA8FF" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="已安装" android:textSize="12sp" android:textColor="#8FA0B5"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:id="@+id/stat_themed"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="26sp" android:textStyle="bold" android:textColor="#34D399" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="已适配" android:textSize="12sp" android:textColor="#8FA0B5"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:id="@+id/stat_unthemed"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="26sp" android:textStyle="bold" android:textColor="#FDBA3B" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="未适配" android:textSize="12sp" android:textColor="#8FA0B5"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Progress bar -->
                    <ProgressBar android:id="@+id/request_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="4dp"
                        android:layout_marginTop="10dp"
                        android:progressDrawable="@drawable/glass_progress" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Filter chips -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp" android:layout_marginBottom="10dp">

                <TextView android:id="@+id/filter_all"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:gravity="center" android:text="@string/request_all" android:textSize="12sp"
                    android:textColor="@color/text_on_primary" android:background="@drawable/glass_chip_selected"
                    android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" />
                <TextView android:id="@+id/filter_themed"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:gravity="center" android:text="@string/request_themed_filter" android:textSize="12sp"
                    android:textColor="@color/text_secondary" android:background="@drawable/glass_chip_unselected"
                    android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" />
                <TextView android:id="@+id/filter_unthemed"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:gravity="center" android:text="@string/request_unthemed_filter" android:textSize="12sp"
                    android:textColor="@color/text_secondary" android:background="@drawable/glass_chip_unselected"
                    android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" />
                <TextView android:id="@+id/filter_selected"
                    android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                    android:gravity="center" android:text="已选择" android:textSize="12sp"
                    android:textColor="@color/text_secondary" android:background="@drawable/glass_chip_unselected"
                    android:clickable="true" android:focusable="true" />
            </LinearLayout>

            <!-- App list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/request_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <!-- 3. FIXED bottom bar: always visible, 3 buttons compact -->
    <LinearLayout android:id="@+id/request_bottom_bar"
        android:layout_width="match_parent" android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp" android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/glass_floating_bar"
        android:gravity="center_vertical" android:orientation="horizontal"
        android:paddingStart="18dp" android:paddingEnd="14dp"
        android:elevation="14dp"
        android:visibility="visible">

        <TextView android:id="@+id/request_selected_count"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="选择图标申请"
            android:textSize="14sp" android:textColor="#F9FAFB" />

        <TextView android:id="@+id/btn_select_all"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:gravity="center" android:text="全选" android:textSize="12sp"
            android:textColor="#E5E7EB" android:background="@drawable/glass_chip_unselected"
            android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginEnd="8dp"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btn_export"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:gravity="center" android:text="@string/request_export" android:textSize="12sp"
            android:textColor="@color/text_on_primary" android:background="@drawable/glass_chip_selected"
            android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginEnd="8dp"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btn_share"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:gravity="center" android:text="@string/request_share" android:textSize="12sp"
            android:textColor="@color/text_on_primary" android:background="@drawable/glass_chip_selected"
            android:paddingStart="14dp" android:paddingEnd="14dp"
            android:clickable="true" android:focusable="true" />

    </LinearLayout>

</FrameLayout>

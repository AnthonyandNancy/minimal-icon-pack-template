<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_clean_mist_dashboard"
    android:clipToPadding="false">

    <LinearLayout android:id="@+id/dashboard_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_padding_horizontal"
        android:paddingEnd="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/page_padding_top"
        android:paddingBottom="@dimen/page_padding_bottom">

        <!-- ══ HEADER ══ -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <FrameLayout
                android:layout_width="@dimen/header_logo_size"
                android:layout_height="@dimen/header_logo_size"
                android:background="@drawable/bg_card_clean"
                android:elevation="2dp">
                <ImageView android:id="@+id/hero_icon"
                    android:layout_width="40dp" android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@mipmap/ic_launcher" android:scaleType="centerCrop"/>
            </FrameLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="16dp">
                <TextView android:id="@+id/hero_app_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/color_text_primary" android:textSize="24sp"
                    android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
                <TextView android:id="@+id/hero_version"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/color_text_secondary" android:textSize="14sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <ImageButton android:id="@+id/btn_menu_home"
                android:layout_width="@dimen/header_menu_size"
                android:layout_height="@dimen/header_menu_size"
                android:background="@drawable/bg_menu_circle_clean"
                android:elevation="2dp"
                android:src="@drawable/ic_menu_glass"
                android:tint="@color/color_primary_clean"
                android:scaleType="centerInside"/>
        </LinearLayout>

        <!-- ══ HERO CARD ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardElevation="2dp" app:cardCornerRadius="@dimen/hero_radius"
            app:strokeWidth="1dp" app:strokeColor="@color/color_card_stroke_light"
            app:cardBackgroundColor="@color/color_card_surface"
            android:layout_marginBottom="28dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:padding="@dimen/hero_card_padding">

                <TextView android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="让你的主屏幕焕然一新"
                    android:textColor="@color/color_text_primary"
                    android:textSize="22sp" android:textStyle="bold"/>

                <TextView android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="精美图标包，适配主流启动器"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="15sp" android:layout_marginTop="8dp"/>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal"
                    android:gravity="center" android:layout_marginTop="28dp">

                    <LinearLayout android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/hero_icon_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="30sp" android:textStyle="bold"
                            android:textColor="@color/color_primary_clean" android:text="0"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="图标"
                            android:textSize="13sp" android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="52dp"
                        android:background="@color/color_divider_soft" android:alpha="0.5"
                        android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>

                    <LinearLayout android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/hero_wallpaper_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="30sp" android:textStyle="bold"
                            android:textColor="@color/color_success" android:text="0"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="壁纸"
                            android:textSize="13sp" android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="52dp"
                        android:background="@color/color_divider_soft" android:alpha="0.5"
                        android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>

                    <LinearLayout android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/hero_themed_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="30sp" android:textStyle="bold"
                            android:textColor="@color/color_neutral_number" android:text="0"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="已适配"
                            android:textSize="13sp" android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ SECTION: 数据概览 ══ -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <View android:layout_width="4dp" android:layout_height="28dp"
                android:background="@drawable/bg_section_bar_blue"/>
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="数据概览"
                android:textSize="20sp" android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <!-- Stats Grid 2x2 -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:layout_marginBottom="28dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Card 1: 图标 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="@dimen/stats_card_height"
                    app:cardElevation="2dp" app:cardCornerRadius="@dimen/card_radius_large"
                    app:strokeWidth="1dp" app:strokeColor="@color/color_card_stroke_light"
                    app:cardBackgroundColor="@color/color_card_surface"
                    android:layout_marginEnd="8dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent" android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="@dimen/normal_card_padding">
                        <FrameLayout android:layout_width="@dimen/stats_icon_badge_size"
                            android:layout_height="@dimen/stats_icon_badge_size"
                            android:background="@drawable/bg_badge_blue">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:layout_gravity="center" android:src="@drawable/ic_rate"
                                android:tint="@color/color_primary_clean"/>
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:layout_marginStart="16dp">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="图标"
                                android:textSize="15sp" android:textColor="@color/color_text_primary"/>
                            <TextView android:id="@+id/stat_icon_count"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="30sp" android:textStyle="bold"
                                android:textColor="@color/color_primary_clean" android:text="0"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="已打包图标"
                                android:textSize="13sp" android:textColor="@color/color_text_tertiary"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card 2: 应用 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="@dimen/stats_card_height"
                    app:cardElevation="2dp" app:cardCornerRadius="@dimen/card_radius_large"
                    app:strokeWidth="1dp" app:strokeColor="@color/color_card_stroke_light"
                    app:cardBackgroundColor="@color/color_card_surface"
                    android:layout_marginStart="8dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent" android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="@dimen/normal_card_padding">
                        <FrameLayout android:layout_width="@dimen/stats_icon_badge_size"
                            android:layout_height="@dimen/stats_icon_badge_size"
                            android:background="@drawable/bg_badge_gray">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:layout_gravity="center" android:src="@drawable/ic_info"
                                android:tint="#4B5563"/>
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:layout_marginStart="16dp">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="应用"
                                android:textSize="15sp" android:textColor="@color/color_text_primary"/>
                            <TextView android:id="@+id/stat_app_count"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="30sp" android:textStyle="bold"
                                android:textColor="@color/color_neutral_number" android:text="0"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="已安装应用"
                                android:textSize="13sp" android:textColor="@color/color_text_tertiary"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal">

                <!-- Card 3: 已适配 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="@dimen/stats_card_height"
                    app:cardElevation="2dp" app:cardCornerRadius="@dimen/card_radius_large"
                    app:strokeWidth="1dp" app:strokeColor="@color/color_card_stroke_light"
                    app:cardBackgroundColor="@color/color_card_surface"
                    android:layout_marginEnd="8dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent" android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="@dimen/normal_card_padding">
                        <FrameLayout android:layout_width="@dimen/stats_icon_badge_size"
                            android:layout_height="@dimen/stats_icon_badge_size"
                            android:background="@drawable/bg_badge_green">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:layout_gravity="center" android:src="@drawable/ic_rate"
                                android:tint="@color/color_success"/>
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:layout_marginStart="16dp">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="已适配"
                                android:textSize="15sp" android:textColor="@color/color_text_primary"/>
                            <TextView android:id="@+id/stat_themed_count"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="30sp" android:textStyle="bold"
                                android:textColor="@color/color_success" android:text="0"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="适配累计"
                                android:textSize="13sp" android:textColor="@color/color_text_tertiary"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card 4: 未适配 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="@dimen/stats_card_height"
                    app:cardElevation="2dp" app:cardCornerRadius="@dimen/card_radius_large"
                    app:strokeWidth="1dp" app:strokeColor="@color/color_card_stroke_light"
                    app:cardBackgroundColor="@color/color_card_surface"
                    android:layout_marginStart="8dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent" android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="@dimen/normal_card_padding">
                        <FrameLayout android:layout_width="@dimen/stats_icon_badge_size"
                            android:layout_height="@dimen/stats_icon_badge_size"
                            android:background="@drawable/bg_badge_red">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:layout_gravity="center" android:src="@drawable/ic_info"
                                android:tint="@color/color_warning"/>
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:layout_marginStart="16dp">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="未适配"
                                android:textSize="15sp" android:textColor="@color/color_text_primary"/>
                            <TextView android:id="@+id/stat_missing_count"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="30sp" android:textStyle="bold"
                                android:textColor="@color/color_warning" android:text="0"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="待适配"
                                android:textSize="13sp" android:textColor="@color/color_text_tertiary"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SECTION: 快捷入口 ══ -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <View android:layout_width="4dp" android:layout_height="28dp"
                android:background="@drawable/bg_section_bar_blue"/>
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="快捷入口"
                android:textSize="20sp" android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <!-- Quick Entry List -->
        <!-- Item 1: 浏览图标 -->
        <LinearLayout android:id="@+id/entry_browse"
            android:layout_width="match_parent"
            android:layout_height="@dimen/quick_item_height"
            android:background="@drawable/bg_quick_item_clean"
            android:elevation="1dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="18dp" android:paddingEnd="16dp"
            android:layout_marginBottom="12dp"
            android:clickable="true" android:focusable="true">

            <FrameLayout android:layout_width="@dimen/quick_icon_badge_size"
                android:layout_height="@dimen/quick_icon_badge_size"
                android:background="@drawable/bg_badge_blue">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:layout_gravity="center" android:src="@drawable/ic_rate"
                    android:tint="@color/color_primary_clean"/>
            </FrameLayout>

            <LinearLayout android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center_vertical"
                android:layout_marginStart="16dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="浏览图标"
                    android:textSize="16sp" android:textColor="@color/color_text_primary"/>
                <TextView android:id="@+id/quick_icons_subtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="@color/color_text_secondary"
                    android:layout_marginTop="2dp" android:text="0 个图标"/>
            </LinearLayout>

            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_arrow_right"
                android:tint="@color/color_text_tertiary"/>
        </LinearLayout>

        <!-- Item 2: 申请图标 -->
        <LinearLayout android:id="@+id/entry_request"
            android:layout_width="match_parent"
            android:layout_height="@dimen/quick_item_height"
            android:background="@drawable/bg_quick_item_clean"
            android:elevation="1dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="18dp" android:paddingEnd="16dp"
            android:layout_marginBottom="12dp"
            android:clickable="true" android:focusable="true">

            <FrameLayout android:layout_width="@dimen/quick_icon_badge_size"
                android:layout_height="@dimen/quick_icon_badge_size"
                android:background="@drawable/bg_badge_blue">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:layout_gravity="center" android:src="@drawable/ic_info"
                    android:tint="@color/color_primary_clean"/>
            </FrameLayout>

            <LinearLayout android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center_vertical"
                android:layout_marginStart="16dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="申请图标"
                    android:textSize="16sp" android:textColor="@color/color_text_primary"/>
                <TextView android:id="@+id/quick_request_subtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="@color/color_text_secondary"
                    android:layout_marginTop="2dp" android:text="0 / 0 已适配"/>
            </LinearLayout>

            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_arrow_right"
                android:tint="@color/color_text_tertiary"/>
        </LinearLayout>

        <!-- Item 3: 壁纸 -->
        <LinearLayout android:id="@+id/entry_wallpaper"
            android:layout_width="match_parent"
            android:layout_height="@dimen/quick_item_height"
            android:background="@drawable/bg_quick_item_clean"
            android:elevation="1dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="18dp" android:paddingEnd="16dp"
            android:clickable="true" android:focusable="true">

            <FrameLayout android:layout_width="@dimen/quick_icon_badge_size"
                android:layout_height="@dimen/quick_icon_badge_size"
                android:background="@drawable/bg_badge_orange">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:layout_gravity="center" android:src="@drawable/ic_wallpaper"
                    android:tint="#D89A3D"/>
            </FrameLayout>

            <LinearLayout android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center_vertical"
                android:layout_marginStart="16dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="壁纸"
                    android:textSize="16sp" android:textColor="@color/color_text_primary"/>
                <TextView android:id="@+id/quick_wallpaper_subtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="@color/color_text_secondary"
                    android:layout_marginTop="2dp" android:text="0 张云端壁纸"/>
            </LinearLayout>

            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_arrow_right"
                android:tint="@color/color_text_tertiary"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="32dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

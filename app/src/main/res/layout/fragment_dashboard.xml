<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingTop="0dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:id="@+id/dashboard_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clipChildren="false"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Spacer for status bar -->
        <View android:layout_width="match_parent" android:layout_height="24dp"
            android:id="@+id/status_spacer" />

        <!-- HOME TOOLBAR: menu icon only, no title -->
        <FrameLayout
            android:id="@+id/toolbar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:elevation="8dp">

            <ImageButton
                android:id="@+id/btn_menu_home"
                android:layout_width="44dp" android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@drawable/glass_btn_bg"
                android:src="@drawable/ic_menu_glass" android:tint="#3D3D5C"
                android:scaleType="centerInside" />
        </FrameLayout>

        <!-- HERO CARD -->
        <com.template.iconpack.ui.glass.LiquidGlassLayout
            android:id="@+id/hero_card"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="16dp"
            android:elevation="8dp"
            android:clipChildren="false"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp" android:paddingEnd="20dp"
                android:paddingTop="14dp" android:paddingBottom="14dp">

                <ImageView android:id="@+id/hero_icon"
                    android:layout_width="76dp" android:layout_height="76dp"
                    android:src="@mipmap/ic_launcher" android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center_vertical" android:layout_marginStart="18dp">

                    <TextView android:id="@+id/hero_app_name"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/app_name" android:textColor="#1A1A2E"
                        android:textSize="22sp" android:textStyle="bold"
                        android:maxLines="1" android:ellipsize="end" />

                    <TextView android:id="@+id/hero_version"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/version_name" android:textColor="#4A4A6A"
                        android:textSize="13sp" android:layout_marginTop="6dp" />

                    <TextView android:id="@+id/hero_icon_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#4D96FF" android:textSize="13sp"
                        android:textStyle="bold" android:layout_marginTop="6dp" />

                </LinearLayout>
            </LinearLayout>

            <TextView android:id="@+id/hero_badge"
                android:layout_width="wrap_content" android:layout_height="28dp"
                android:layout_gravity="top|end" android:layout_marginTop="14dp"
                android:layout_marginEnd="14dp" android:gravity="center"
                android:text="Template" android:textSize="12sp" android:textColor="#FFFFFF"
                android:background="@drawable/glass_badge_blue"
                android:paddingStart="12dp" android:paddingEnd="12dp" />
        </com.template.iconpack.ui.glass.LiquidGlassLayout>

        <!-- Stats section -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="概述" android:textSize="18sp" android:textStyle="bold"
            android:textColor="#1A1A2E" android:layout_marginBottom="14dp" />
        <GridLayout android:id="@+id/dashboard_stats"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="2" android:orientation="horizontal"
            android:clipChildren="false" android:layout_marginBottom="24dp" />

        <!-- Features section -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="功能" android:textSize="18sp" android:textStyle="bold"
            android:textColor="#1A1A2E" android:layout_marginBottom="14dp" />
        <LinearLayout android:id="@+id/dashboard_entries"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:clipChildren="false" />

    </LinearLayout>
</ScrollView>

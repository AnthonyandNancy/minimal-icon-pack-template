<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingTop="56dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:id="@+id/dashboard_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- HERO CARD: FrameLayout + glass background, no MaterialCardView -->
        <FrameLayout
            android:id="@+id/hero_card"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/glass_card_hero"
            android:elevation="8dp"
            android:clipChildren="false"
            android:clickable="true"
            android:focusable="true"
            android:outlineProvider="background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- App icon -->
                <ImageView
                    android:id="@+id/hero_icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop"
                    android:background="@drawable/glass_hero_icon_bg" />

                <!-- Text column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/hero_app_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="#111827"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/hero_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/version_name"
                        android:textColor="#5F6B7A"
                        android:textSize="13sp"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/hero_icon_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#3B82F6"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Template badge — positioned at top-right -->
            <TextView
                android:id="@+id/hero_badge"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="14dp"
                android:gravity="center"
                android:text="Template"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/glass_badge_blue"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

        </FrameLayout>

        <!-- Quick action buttons -->
        <LinearLayout
            android:id="@+id/quick_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/btn_quick_rate"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/glass_btn_bg"
                android:elevation="2dp"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:outlineProvider="background">

                <ImageView
                    android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_rate" android:tint="#3B82F6" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/action_rate" android:textSize="14sp"
                    android:textColor="#111827" android:layout_marginStart="6dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_quick_share"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/glass_btn_bg"
                android:elevation="2dp"
                android:layout_marginEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:outlineProvider="background">

                <ImageView
                    android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_share" android:tint="#7C5CFF" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/action_share" android:textSize="14sp"
                    android:textColor="#111827" android:layout_marginStart="6dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_quick_refresh"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/glass_btn_bg"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"
                android:outlineProvider="background">

                <ImageView
                    android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_refresh" android:tint="#3B82F6" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/action_refresh" android:textSize="14sp"
                    android:textColor="#111827" android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Section: Stats -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="概述"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginBottom="12dp" />

        <GridLayout
            android:id="@+id/dashboard_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:orientation="horizontal"
            android:clipChildren="false"
            android:layout_marginBottom="24dp" />

        <!-- Section: Features -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="功能"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/dashboard_entries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false" />

    </LinearLayout>

</ScrollView>

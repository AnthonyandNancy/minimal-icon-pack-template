<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_clean_mist_dashboard"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_padding_horizontal"
        android:paddingEnd="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/page_padding_top"
        android:paddingBottom="@dimen/page_padding_bottom">

        <!-- ══ HEADER ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/header_to_hero">

            <ImageView
                android:id="@+id/hero_icon"
                android:layout_width="@dimen/header_logo_size"
                android:layout_height="@dimen/header_logo_size"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitCenter" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/hero_app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/header_title_size"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"/>
                <TextView
                    android:id="@+id/hero_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/header_version_size"
                    android:layout_marginTop="3dp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_menu_home"
                android:layout_width="@dimen/header_menu_size"
                android:layout_height="@dimen/header_menu_size"
                android:background="@drawable/bg_menu_circle_clean"
                android:elevation="0dp"
                android:src="@drawable/ic_menu_glass"
                android:tint="@color/color_primary_clean"
                android:scaleType="centerInside"/>
        </LinearLayout>

        <!-- ══ HERO CARD ══ -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.IconPack.Card.Hero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/hero_to_section">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/hero_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="让你的主屏幕焕然一新"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/hero_title_size"
                    android:textStyle="bold"
                    android:includeFontPadding="false"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="精美图标包，适配主流启动器"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/hero_subtitle_size"
                    android:layout_marginTop="7dp"
                    android:includeFontPadding="false"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="24dp">

                    <LinearLayout
                        android:id="@+id/hero_stat_icons"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/hero_icon_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/hero_number_size"
                            android:textStyle="bold"
                            android:textColor="@color/color_primary_clean"
                            android:text="0"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="图标"
                            android:textSize="@dimen/hero_label_size"
                            android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="@dimen/hero_divider_height"
                        android:background="@color/color_divider_soft"
                        android:alpha="0.6"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>

                    <LinearLayout
                        android:id="@+id/hero_stat_wallpapers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/hero_wallpaper_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/hero_number_size"
                            android:textStyle="bold"
                            android:textColor="@color/color_success"
                            android:text="0"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="壁纸"
                            android:textSize="@dimen/hero_label_size"
                            android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="@dimen/hero_divider_height"
                        android:background="@color/color_divider_soft"
                        android:alpha="0.6"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>

                    <LinearLayout
                        android:id="@+id/hero_stat_themed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/hero_themed_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/hero_number_size"
                            android:textStyle="bold"
                            android:textColor="@color/color_neutral_number"
                            android:text="0"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已适配"
                            android:textSize="@dimen/hero_label_size"
                            android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ SECTION: 数据概览 ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/section_to_content">

            <View
                android:layout_width="@dimen/section_bar_width"
                android:layout_height="@dimen/section_bar_height"
                android:background="@drawable/bg_section_bar_blue"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数据概览"
                android:textSize="@dimen/section_title_size"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginStart="9dp"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- Stats Grid 2x2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/section_gap">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/stat_card_gap">

                <com.google.android.material.card.MaterialCardView android:id="@+id/stat_card_icons"
                    style="@style/Widget.IconPack.Card"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/stat_card_min_height"
                    android:layout_marginEnd="7dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:minHeight="@dimen/stat_card_min_height"
                        android:orientation="vertical"
                        android:padding="@dimen/stat_card_padding">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <FrameLayout android:id="@+id/card_badge" android:layout_width="@dimen/stat_badge_size" android:layout_height="@dimen/stat_badge_size">
                                <ImageView android:id="@+id/card_badge_icon" android:layout_width="@dimen/stat_badge_icon_size" android:layout_height="@dimen/stat_badge_icon_size" android:layout_gravity="center"/>
                            </FrameLayout>
                            <TextView android:id="@+id/card_title_label" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:layout_marginStart="12dp"
                                android:textSize="@dimen/stat_title_size" android:textColor="@color/color_text_primary"
                                android:textStyle="bold"
                                android:maxLines="1" android:ellipsize="end"/>
                        </LinearLayout>
                        <TextView android:id="@+id/card_value" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textSize="@dimen/stat_number_size" android:textStyle="bold"
                            android:maxLines="1" android:ellipsize="end"
                            android:layout_marginTop="6dp"/>
                        <TextView android:id="@+id/card_subtitle" android:layout_width="match_parent" android:layout_height="@dimen/stat_subtitle_line_height"
                            android:gravity="center_vertical"
                            android:textSize="@dimen/stat_subtitle_size" android:textColor="@color/color_text_tertiary"
                            android:maxLines="1" android:ellipsize="end"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:id="@+id/stat_card_apps"
                    style="@style/Widget.IconPack.Card"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/stat_card_min_height"
                    android:layout_marginStart="7dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:minHeight="@dimen/stat_card_min_height"
                        android:orientation="vertical"
                        android:padding="@dimen/stat_card_padding">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <FrameLayout android:id="@+id/card_badge2" android:layout_width="@dimen/stat_badge_size" android:layout_height="@dimen/stat_badge_size">
                                <ImageView android:id="@+id/card_badge_icon2" android:layout_width="@dimen/stat_badge_icon_size" android:layout_height="@dimen/stat_badge_icon_size" android:layout_gravity="center"/>
                            </FrameLayout>
                            <TextView android:id="@+id/card_title_label2" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:layout_marginStart="12dp"
                                android:textSize="@dimen/stat_title_size" android:textColor="@color/color_text_primary"
                                android:textStyle="bold"
                                android:maxLines="1" android:ellipsize="end"/>
                        </LinearLayout>
                        <TextView android:id="@+id/card_value2" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textSize="@dimen/stat_number_size" android:textStyle="bold"
                            android:maxLines="1" android:ellipsize="end"
                            android:layout_marginTop="6dp"/>
                        <TextView android:id="@+id/card_subtitle2" android:layout_width="match_parent" android:layout_height="@dimen/stat_subtitle_line_height"
                            android:gravity="center_vertical"
                            android:textSize="@dimen/stat_subtitle_size" android:textColor="@color/color_text_tertiary"
                            android:maxLines="1" android:ellipsize="end"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView android:id="@+id/stat_card_themed"
                    style="@style/Widget.IconPack.Card"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/stat_card_min_height"
                    android:layout_marginEnd="7dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:minHeight="@dimen/stat_card_min_height"
                        android:orientation="vertical"
                        android:padding="@dimen/stat_card_padding">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <FrameLayout android:id="@+id/card_badge3" android:layout_width="@dimen/stat_badge_size" android:layout_height="@dimen/stat_badge_size">
                                <ImageView android:id="@+id/card_badge_icon3" android:layout_width="@dimen/stat_badge_icon_size" android:layout_height="@dimen/stat_badge_icon_size" android:layout_gravity="center"/>
                            </FrameLayout>
                            <TextView android:id="@+id/card_title_label3" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:layout_marginStart="12dp"
                                android:textSize="@dimen/stat_title_size" android:textColor="@color/color_text_primary"
                                android:textStyle="bold"
                                android:maxLines="1" android:ellipsize="end"/>
                        </LinearLayout>
                        <TextView android:id="@+id/card_value3" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textSize="@dimen/stat_number_size" android:textStyle="bold"
                            android:maxLines="1" android:ellipsize="end"
                            android:layout_marginTop="6dp"/>
                        <TextView android:id="@+id/card_subtitle3" android:layout_width="match_parent" android:layout_height="@dimen/stat_subtitle_line_height"
                            android:gravity="center_vertical"
                            android:textSize="@dimen/stat_subtitle_size" android:textColor="@color/color_text_tertiary"
                            android:maxLines="1" android:ellipsize="end"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:id="@+id/stat_card_missing"
                    style="@style/Widget.IconPack.Card"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/stat_card_min_height"
                    android:layout_marginStart="7dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:minHeight="@dimen/stat_card_min_height"
                        android:orientation="vertical"
                        android:padding="@dimen/stat_card_padding">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <FrameLayout android:id="@+id/card_badge4" android:layout_width="@dimen/stat_badge_size" android:layout_height="@dimen/stat_badge_size">
                                <ImageView android:id="@+id/card_badge_icon4" android:layout_width="@dimen/stat_badge_icon_size" android:layout_height="@dimen/stat_badge_icon_size" android:layout_gravity="center"/>
                            </FrameLayout>
                            <TextView android:id="@+id/card_title_label4" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:layout_marginStart="12dp"
                                android:textSize="@dimen/stat_title_size" android:textColor="@color/color_text_primary"
                                android:textStyle="bold"
                                android:maxLines="1" android:ellipsize="end"/>
                        </LinearLayout>
                        <TextView android:id="@+id/card_value4" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textSize="@dimen/stat_number_size" android:textStyle="bold"
                            android:maxLines="1" android:ellipsize="end"
                            android:layout_marginTop="6dp"/>
                        <TextView android:id="@+id/card_subtitle4" android:layout_width="match_parent" android:layout_height="@dimen/stat_subtitle_line_height"
                            android:gravity="center_vertical"
                            android:textSize="@dimen/stat_subtitle_size" android:textColor="@color/color_text_tertiary"
                            android:maxLines="1" android:ellipsize="end"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SECTION: 找到我 ══ -->
        <LinearLayout
            android:id="@+id/find_me_section_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/section_to_content">

            <View
                android:layout_width="@dimen/section_bar_width"
                android:layout_height="@dimen/section_bar_height"
                android:background="@drawable/bg_section_bar_blue"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="找到我"
                android:textSize="@dimen/section_title_size"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginStart="9dp"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dashboard_entries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

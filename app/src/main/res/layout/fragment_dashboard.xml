<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_clean_mist_dashboard"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_padding_horizontal"
        android:paddingEnd="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/page_padding_top"
        android:paddingBottom="@dimen/page_padding_bottom">

        <!-- ══ HEADER ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/header_to_hero">

            <FrameLayout
                android:layout_width="@dimen/header_logo_size"
                android:layout_height="@dimen/header_logo_size"
                android:background="@drawable/bg_card_clean"
                android:elevation="1dp">
                <ImageView
                    android:id="@+id/hero_icon"
                    android:layout_width="@dimen/header_logo_inner_icon"
                    android:layout_height="@dimen/header_logo_inner_icon"
                    android:layout_gravity="center"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp">
                <TextView
                    android:id="@+id/hero_app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/header_title_size"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"/>
                <TextView
                    android:id="@+id/hero_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/header_version_size"
                    android:layout_marginTop="3dp"
                    android:includeFontPadding="false"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_menu_home"
                android:layout_width="@dimen/header_menu_size"
                android:layout_height="@dimen/header_menu_size"
                android:background="@drawable/bg_menu_circle_clean"
                android:elevation="1dp"
                android:src="@drawable/ic_menu_glass"
                android:tint="@color/color_primary_clean"
                android:scaleType="centerInside"/>
        </LinearLayout>

        <!-- ══ HERO CARD ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_hero"
            app:cardElevation="1dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/color_card_stroke_light"
            app:cardBackgroundColor="@color/color_card_surface"
            android:layout_marginBottom="@dimen/hero_to_section">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/hero_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="让你的主屏幕焕然一新"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/hero_title_size"
                    android:textStyle="bold"
                    android:includeFontPadding="false"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="精美图标包，适配主流启动器"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/hero_subtitle_size"
                    android:layout_marginTop="7dp"
                    android:includeFontPadding="false"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/hero_icon_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/hero_number_size"
                            android:textStyle="bold"
                            android:textColor="@color/color_primary_clean"
                            android:text="0"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="图标"
                            android:textSize="@dimen/hero_label_size"
                            android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="@dimen/hero_divider_height"
                        android:background="@color/color_divider_soft"
                        android:alpha="0.6"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/hero_wallpaper_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/hero_number_size"
                            android:textStyle="bold"
                            android:textColor="@color/color_success"
                            android:text="0"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="壁纸"
                            android:textSize="@dimen/hero_label_size"
                            android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="@dimen/hero_divider_height"
                        android:background="@color/color_divider_soft"
                        android:alpha="0.6"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/hero_themed_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/hero_number_size"
                            android:textStyle="bold"
                            android:textColor="@color/color_neutral_number"
                            android:text="0"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已适配"
                            android:textSize="@dimen/hero_label_size"
                            android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ SECTION: 数据概览 ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/hero_to_section"
            android:layout_marginBottom="@dimen/section_to_content">

            <View
                android:layout_width="@dimen/section_bar_width"
                android:layout_height="@dimen/section_bar_height"
                android:background="@drawable/bg_section_bar_blue"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数据概览"
                android:textSize="@dimen/section_title_size"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginStart="9dp"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- Stats Grid 2x2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/section_gap">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/stat_card_gap">

                <include layout="@layout/item_dashboard_card"
                    android:id="@+id/stat_card_icons"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"/>

                <include layout="@layout/item_dashboard_card"
                    android:id="@+id/stat_card_apps"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="7dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <include layout="@layout/item_dashboard_card"
                    android:id="@+id/stat_card_themed"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"/>

                <include layout="@layout/item_dashboard_card"
                    android:id="@+id/stat_card_missing"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="7dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SECTION: 快捷入口 ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/section_gap"
            android:layout_marginBottom="@dimen/section_to_content">

            <View
                android:layout_width="@dimen/section_bar_width"
                android:layout_height="@dimen/section_bar_height"
                android:background="@drawable/bg_section_bar_blue"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="快捷入口"
                android:textSize="@dimen/section_title_size"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginStart="9dp"
                android:includeFontPadding="false"/>
        </LinearLayout>

        <!-- Quick Entry List (dynamically populated by DashboardFragment) -->
        <LinearLayout
            android:id="@+id/dashboard_entries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

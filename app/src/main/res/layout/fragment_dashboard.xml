<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:background="@color/background"
    android:paddingBottom="32dp">

    <LinearLayout
        android:id="@+id/dashboard_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp">

        <View android:id="@+id/status_spacer"
            android:layout_width="match_parent" android:layout_height="24dp"/>

        <!-- ══ BRAND BAR ══ -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingTop="12dp" android:paddingBottom="16dp">

            <ImageView android:id="@+id/hero_icon"
                android:layout_width="48dp" android:layout_height="48dp"
                android:src="@mipmap/ic_launcher" android:scaleType="centerCrop"
                android:layout_marginEnd="12dp"/>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/hero_app_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="20sp"
                    android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
                <TextView android:id="@+id/hero_version"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <ImageButton android:id="@+id/btn_menu_home"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_surface_card"
                android:src="@drawable/ic_menu_glass" android:tint="@color/text_secondary"
                android:scaleType="centerInside"/>
        </LinearLayout>

        <!-- ══ HERO CARD ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="28dp" app:cardElevation="2dp"
            app:cardBackgroundColor="@color/surface"
            app:strokeColor="@color/outline_variant" app:strokeWidth="1dp"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:padding="20dp">

                <TextView android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="让你的主屏幕焕然一新" android:textColor="@color/text_primary"
                    android:textSize="18sp" android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="精美图标包，适配主流启动器"
                    android:textColor="@color/text_secondary" android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center"
                    android:layout_marginBottom="16dp">
                    <LinearLayout android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/stat_icons"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/primary" android:textSize="24sp"
                            android:textStyle="bold" android:text="0"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="图标"
                            android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/stat_wallpapers"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/status_themed" android:textSize="24sp"
                            android:textStyle="bold" android:text="0"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="壁纸"
                            android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/stat_themed"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_primary" android:textSize="24sp"
                            android:textStyle="bold" android:text="0"/>
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="已适配"
                            android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView android:id="@+id/btn_apply"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:gravity="center" android:text="应用图标包"
                    android:textColor="@color/text_on_primary" android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_pill_primary"
                    android:clickable="true" android:focusable="true"/>

                <TextView android:id="@+id/btn_request"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:gravity="center" android:text="申请适配缺失应用"
                    android:textColor="@color/primary" android:textSize="14sp"
                    android:background="@drawable/bg_surface_card"
                    android:layout_marginTop="10dp"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ QUICK STATS ══ -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="数据概览" android:textColor="@color/text_primary"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <GridLayout android:id="@+id/dashboard_stats"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="2" android:useDefaultMargins="true"
            android:layout_marginBottom="24dp"/>

        <!-- ══ QUICK ENTRY ══ -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="快捷入口" android:textColor="@color/text_primary"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <LinearLayout android:id="@+id/dashboard_entries"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <View android:layout_width="match_parent" android:layout_height="80dp"/>
    </LinearLayout>
</ScrollView>

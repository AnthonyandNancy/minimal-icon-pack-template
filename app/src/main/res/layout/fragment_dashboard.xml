<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboard_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingBottom="24dp">

    <LinearLayout
        android:id="@+id/dashboard_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp">

        <View android:id="@+id/status_spacer"
            android:layout_width="match_parent" android:layout_height="24dp" />

        <!-- Brand header -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="8dp" android:layout_marginBottom="12dp"
            android:paddingStart="4dp">

            <ImageView android:id="@+id/hero_icon"
                android:layout_width="52dp" android:layout_height="52dp"
                android:src="@mipmap/ic_launcher" android:scaleType="centerCrop"
                android:layout_marginEnd="14dp" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/hero_app_name" android:textColor="#181821"
                    android:textSize="22sp" android:textStyle="bold" />
                <TextView android:id="@+id/hero_version" android:textColor="#6E6A78"
                    android:textSize="13sp" android:layout_marginTop="2dp" />
            </LinearLayout>

            <ImageButton android:id="@+id/btn_menu_home"
                android:layout_width="44dp" android:layout_height="44dp"
                android:background="@drawable/bg_circle_surface"
                android:src="@drawable/ic_menu_glass" android:tint="#6E6A78"
                android:scaleType="centerInside" />
        </LinearLayout>

        <!-- Hero card: icon preview + apply button -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardCornerRadius="28dp" app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeColor="#E7E1EF" app:strokeWidth="1dp"
            android:layout_marginBottom="20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/dashboard_title" android:textColor="#181821"
                    android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="6dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Beautiful icons for your home screen" android:textColor="#6E6A78"
                    android:textSize="14sp" android:layout_marginBottom="18dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center">

                    <TextView android:id="@+id/stat_icons" android:textColor="#181821"
                        android:textStyle="bold" android:textSize="16sp" android:text="0" />
                    <TextView android:text=" icons" android:textColor="#6E6A78" android:textSize="14sp"
                        android:layout_marginEnd="24dp" />
                    <TextView android:id="@+id/stat_wallpapers" android:textColor="#181821"
                        android:textStyle="bold" android:textSize="16sp" android:text="0" />
                    <TextView android:text=" wallpapers" android:textColor="#6E6A78" android:textSize="14sp" />
                </LinearLayout>

                <TextView android:id="@+id/btn_apply"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:gravity="center" android:text="Apply Icons" android:textColor="#FFFFFF"
                    android:textSize="16sp" android:textStyle="bold"
                    android:background="@drawable/bg_pill_primary"
                    android:layout_marginTop="18dp"
                    android:clickable="true" android:focusable="true" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick actions grid -->
        <GridLayout android:id="@+id/dashboard_stats"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="2" android:useDefaultMargins="true"
            android:layout_marginBottom="20dp" />

        <!-- Entry cards -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Features" android:textColor="#181821"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout android:id="@+id/dashboard_entries"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View android:layout_width="match_parent" android:layout_height="80dp" />
    </LinearLayout>
</ScrollView>

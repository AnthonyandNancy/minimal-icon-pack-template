<?xml version="1.0" encoding="utf-8"?>
<!-- Liquid glass: high-transparency white + bright highlight + soft edge -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item><shape><solid android:color="@color/glass_card"/><corners android:radius="26dp"/></shape></item>
    <item><shape><gradient android:startColor="@color/glass_overlay" android:endColor="@android:color/transparent" android:angle="135"/><corners android:radius="26dp"/></shape></item>
    <item><shape><stroke android:width="0.5dp" android:color="@color/glass_stroke_bright"/><solid android:color="@android:color/transparent"/><corners android:radius="26dp"/></shape></item>
</layer-list>

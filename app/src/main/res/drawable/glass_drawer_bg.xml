<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Layer 1: Base tinted glass -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#B8F4F8FF"/>
        </shape>
    </item>
    <!-- Layer 2: Top-left highlight gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#44FFFFFF"
                android:centerColor="#10FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="135"
                android:type="linear"/>
        </shape>
    </item>
    <!-- Layer 3: Bright edge stroke overlay -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#88FFFFFF"/>
            <solid android:color="#00000000"/>
        </shape>
    </item>
</layer-list>
